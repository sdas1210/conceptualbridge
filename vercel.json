{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/fetch-jobs",
      "destination": "/api/fetch-jobs.js"
    },
    {
      "source": "/api/fetch-questions",
      "destination": "/api/fetch-questions.js"
    },
    {
      "source": "/api/admin-stats",
      "destination": "/api/admin-stats.js"
    }
  ],
  "functions": {
    "api/fetch-questions.js": {
      "includeFiles": "questions/**"
    },
    "api/admin-stats.js": {
      "includeFiles": "questions/**"
    }
  }
}
